generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model InternshipApplication {
  id             String            @id
  firstName      String
  lastName       String
  email          String
  universityId   String
  majorId        String
  semester       String
  portfolioUrl   String?
  motivation     String
  cvUrl          String?
  roleId         String
  status         ApplicationStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime
  Major          Major             @relation(fields: [majorId], references: [id])
  InternshipRole InternshipRole    @relation(fields: [roleId], references: [id])
  University     University        @relation(fields: [universityId], references: [id])

  @@index([createdAt])
  @@index([email])
  @@index([firstName])
  @@index([lastName])
  @@index([status])
}

model InternshipRole {
  id                    String                  @id
  title                 String
  department            String
  type                  String
  location              String
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  slug                  String                  @unique
  requirements          String[]
  responsibilities      String[]
  InternshipApplication InternshipApplication[]
}

model Major {
  id                    String                  @id
  name                  String                  @unique
  InternshipApplication InternshipApplication[]
}

model PaymentAccount {
  id            String   @id
  userId        String
  type          String
  providerName  String
  accountNumber String
  accountName   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  User          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model University {
  id                    String                  @id
  name                  String                  @unique
  InternshipApplication InternshipApplication[]
}

model User {
  id             String           @id
  name           String?
  email          String?          @unique
  emailVerified  DateTime?
  image          String?
  role           String?          @default("user")
  password       String?
  referral_code  String?          @db.VarChar
  status         Boolean          @default(false)
  Account        Account[]
  PaymentAccount PaymentAccount[]
  Session        Session[]
  PortfolioPost  PortfolioPost[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model payments {
  id             Int          @id @default(autoincrement())
  order_id       String       @unique @db.VarChar(255)
  name           String       @db.VarChar(255)
  email          String       @db.VarChar(255)
  phone          String       @db.VarChar(20)
  amount         Decimal      @default(145000) @db.Decimal(12, 2)
  status         String?      @default("pending") @db.VarChar(50)
  midtrans_token String?      @db.VarChar(255)
  created_at     DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?    @default(now()) @db.Timestamptz(6)
  referral_code  String?      @db.VarChar(255)
  withdrawId     String?      @db.VarChar(255)
  withdrawals    withdrawals? @relation(fields: [withdrawId], references: [id])
}

model ukasir_token {
  token_number  String    @id @db.VarChar(255)
  register_date DateTime? @default(now()) @db.Timestamp(6)
  status_active Boolean?  @default(true)
  device_id     String?   @db.VarChar(255)
  device_name   String?   @db.VarChar(255)
  device_type   String?   @db.VarChar(255)
  order_id      String?   @db.VarChar(255)
  name          String?   @db.VarChar(255)
  email         String?   @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  referral_code String?   @db.VarChar(255)
}

model withdrawals {
  id             String     @id
  amount         Int
  status         String     @default("pending")
  user_email     String
  bank_name      String
  account_number String
  account_name   String
  created_at     DateTime   @default(now())
  updated_at     DateTime
  payments       payments[]

  @@index([user_email])
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  INTERVIEWING
  OFFERED
  REJECTED
  ACCEPTED
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PortfolioStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

model PortfolioPost {
  id          String          @id @default(cuid())
  userId      String
  title       String
  slug        String          @unique
  description String?         @db.Text
  content     String?         @db.Text
  imageUrl    String?
  projectUrl  String?
  status      PortfolioStatus @default(DRAFT)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  User        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Article {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  excerpt     String?
  content     String?        @db.Text
  category    String
  imageUrl    String?
  authorName  String
  authorImage String?
  authorRole  String?
  readTime    String         @default("5 min read")
  isFeatured  Boolean        @default(false)
  isTrending  Boolean        @default(false)
  status      ArticleStatus  @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([category])
  @@index([status])
  @@index([isFeatured])
  @@index([isTrending])
}

// ==========================================
// Landing Page CMS Models (Phase 2)
// ==========================================

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., 'hero_title', 'hero_subtitle'
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  iconName    String   // e.g., 'Globe', 'Smartphone' (matches Lucide icons)
  order       Int      @default(0) // For sorting display order
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  image       String?  // Optional for now until image upload
  linkedinUrl String?
  twitterUrl  String?
  githubUrl   String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  clientName  String
  clientRole  String
  company     String?
  content     String   @db.Text
  image       String?
  rating      Int      @default(5)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// Company Projects Model
// ==========================================

model CompanyProject {
  id          String   @id @default(cuid())
  title       String
  client      String
  category    String   // e.g. Finance, Retail
  tags        String[] // e.g. ["Mobile App", "React"]
  description String   @db.Text
  stats       String   // e.g. "5M+ Users"
  image       String?  // Cover image
  projectUrl  String?
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id           String   @id @default(cuid())
  name         String                    // e.g., "U-Kasir", "U-Cademic"
  slug         String   @unique          // URL: /products/ukasir, /products/u-cademic
  tagline      String                    // Short category badge: "Retail POS", "Education"
  description  String   @db.Text         // Hero description text
  iconName     String   @default("Box")  // Lucide icon for showcase cards
  features     String[]                  // List of feature headlines for showcase card
  heroTitle    String?                   // Hero section H1 (e.g., "Smart Campus Ecosystem.")
  heroGradient String?                   // Tailwind gradient: "from-orange-500 to-red-600"
  ctaText      String   @default("Request Demo")  // CTA button text
  ctaLink      String   @default("/contact")       // CTA button link
  content      String?  @db.Text         // Full product page HTML (for dynamic [slug] page)
  imageUrl     String?                   // Product screenshot/cover image
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
